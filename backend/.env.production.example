# ── PROD environment — set these in Render.com dashboard, NOT in a file ───────
# Render: Your service → Environment → Add Environment Variable

# Neon PROD (main branch) connection string — use the POOLED url
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<prod-branch>.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15

# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=<strong-random-secret>

PORT=4000
NODE_ENV=production
FRONTEND_URL=https://petgearhub.co.uk

AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
EBAY_APP_ID=
EBAY_CLIENT_SECRET=
