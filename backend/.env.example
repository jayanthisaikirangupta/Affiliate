# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
# PostgreSQL connection string — use Neon's POOLED connection string (port 6432) for production
# Local: postgresql://admin:password@localhost:5432/petgearhub
# Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech:6432/petgearhub?sslmode=require&pgbouncer=true
DATABASE_URL=postgresql://admin:securepassword123@localhost:5432/petgearhub

# ──────────────────────────────────────────────
# AUTH
# ──────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ──────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# AMAZON PRODUCT ADVERTISING API
# ──────────────────────────────────────────────
# 1. Sign up for Amazon Associates: https://affiliate-program.amazon.com
# 2. Register for PA-API: https://webservices.amazon.com/paapi5/documentation
# 3. Get your credentials from the PA-API console
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your-tag-20

# ──────────────────────────────────────────────
# EBAY BROWSE API
# ──────────────────────────────────────────────
# 1. Register at https://developer.ebay.com
# 2. Create an application to get your App ID
EBAY_APP_ID=
EBAY_CLIENT_SECRET=
